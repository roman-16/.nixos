{
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"${workspaceFolder}\").inputs.nixpkgs { }"
      },
      "options": {
        "home-manager": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.roman-nixos.options.home-manager.users.type.getSubOptions []"
        },
        "nixos-homelab": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.homelab.options"
        },
        "nixos-roman": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.roman-nixos.options"
        }
      }
    }
  }
}
